+
+test("accepts equivalent JSON only when signed against its exact raw body", () => {
+  const compact = "{\"id\":\"evt_1\",\"type\":\"invoice.paid\",\"amount\":4200}";
+  const spaced = "{\n  \"id\": \"evt_1\",\n  \"type\": \"invoice.paid\",\n  \"amount\": 4200\n}";
+
+  assert.equal(verifyWebhookSignature(spaced, signRaw(spaced), secret), true);
+  assert.equal(verifyWebhookSignature(spaced, signRaw(compact), secret), false);
+});
+
+test("rejects raw body changes even when parsed JSON would be equivalent", () => {
+  const body = "{\n  \"id\": \"evt_1\",\n  \"type\": \"invoice.paid\",\n  \"amount\": 4200\n}";
+  const tampered = `${body}\n`;
+
+  assert.equal(verifyWebhookSignature(tampered, signRaw(body), secret), false);
+});
