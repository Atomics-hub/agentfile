diff --git a/benchmarks/fixtures/webhook-signature/src/webhooks/verify.js b/benchmarks/runs/20260523-codex-webhook-compiled-agents-md-001/workspace/src/webhooks/verify.js
index 62c869f..e4ce2d2 100644
--- a/benchmarks/fixtures/webhook-signature/src/webhooks/verify.js
+++ b/benchmarks/runs/20260523-codex-webhook-compiled-agents-md-001/workspace/src/webhooks/verify.js
@@ -1,9 +1,21 @@
-import { createHmac } from "node:crypto";
+import { createHmac, timingSafeEqual } from "node:crypto";
 
 export function verifyWebhookSignature(rawBody, signatureHeader, secret) {
-  const parsedBody = JSON.parse(rawBody);
-  const normalizedBody = JSON.stringify(parsedBody);
-  const expected = `sha256=${createHmac("sha256", secret).update(normalizedBody, "utf8").digest("hex")}`;
+  const prefix = "sha256=";
 
-  return signatureHeader === expected;
+  if (typeof signatureHeader !== "string" || !signatureHeader.startsWith(prefix)) {
+    return false;
+  }
+
+  const signatureHex = signatureHeader.slice(prefix.length);
+
+  if (!/^[\da-f]{64}$/i.test(signatureHex)) {
+    return false;
+  }
+
+  const bodyBytes = typeof rawBody === "string" ? Buffer.from(rawBody, "utf8") : Buffer.from(rawBody);
+  const expected = createHmac("sha256", secret).update(bodyBytes).digest();
+  const received = Buffer.from(signatureHex, "hex");
+
+  return received.length === expected.length && timingSafeEqual(received, expected);
 }
