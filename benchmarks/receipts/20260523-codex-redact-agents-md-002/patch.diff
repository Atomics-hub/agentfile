+const REDACTED_AUTH_VALUE = "[REDACTED]";
+
+function redactAuthEvent(event) {
+  return {
+    ...event,
+    refreshToken: event.refreshToken == null ? event.refreshToken : REDACTED_AUTH_VALUE,
+    accessToken: event.accessToken == null ? event.accessToken : REDACTED_AUTH_VALUE
+  };
+}
+
 export function formatAuthLog(event) {
