+
+test("verifies equivalent JSON against its exact raw bytes", () => {
+  const compactBody = "{\"id\":\"evt_1\",\"type\":\"invoice.paid\",\"amount\":4200}";
+  const spacedBody = "{\n  \"id\": \"evt_1\",\n  \"type\": \"invoice.paid\",\n  \"amount\": 4200\n}";
+
+  assert.equal(verifyWebhookSignature(spacedBody, signRaw(spacedBody), secret), true);
+  assert.equal(verifyWebhookSignature(spacedBody, signRaw(compactBody), secret), false);
+});
+
+test("rejects malformed signature headers", () => {
+  const body = "{\"id\":\"evt_1\",\"type\":\"invoice.paid\",\"amount\":4200}";
+
+  assert.equal(verifyWebhookSignature(body, "sha256=not-hex", secret), false);
+  assert.equal(verifyWebhookSignature(body, signRaw(body).slice(0, -2), secret), false);
+});
