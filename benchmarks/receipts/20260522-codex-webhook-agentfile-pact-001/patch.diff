+import { createHmac, timingSafeEqual } from "node:crypto";
 
 export function verifyWebhookSignature(rawBody, signatureHeader, secret) {
-  const parsedBody = JSON.parse(rawBody);
-  const normalizedBody = JSON.stringify(parsedBody);
-  const expected = `sha256=${createHmac("sha256", secret).update(normalizedBody, "utf8").digest("hex")}`;
+  const prefix = "sha256=";
 
-  return signatureHeader === expected;
+  if (typeof signatureHeader !== "string" || !signatureHeader.startsWith(prefix)) {
+    return false;
+  }
+
+  const providedHex = signatureHeader.slice(prefix.length);
+
+  if (!/^[a-f0-9]{64}$/i.test(providedHex)) {
+    return false;
+  }
+
+  const expected = createHmac("sha256", secret).update(rawBody).digest();
+  const provided = Buffer.from(providedHex, "hex");
+
+  return timingSafeEqual(provided, expected);
 }
