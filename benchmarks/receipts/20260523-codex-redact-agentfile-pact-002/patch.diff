 });
+
+test("omits raw auth tokens from serialized log lines", () => {
+  const line = formatAuthLog({
+    type: "refresh",
+    userId: "user-3",
+    refreshToken: "refresh-token-secret",
+    accessToken: "access-token-secret"
+  });
+
+  const parsed = JSON.parse(line);
+
+  assert.equal(parsed.type, "refresh");
+  assert.equal(parsed.userId, "user-3");
+  assert.ok(!line.includes("refresh-token-secret"));
+  assert.ok(!line.includes("access-token-secret"));
