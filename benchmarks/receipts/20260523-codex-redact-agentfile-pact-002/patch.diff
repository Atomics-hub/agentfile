--- a/src/auth/logging.js
+++ b/src/auth/logging.js
@@ -1,10 +1,17 @@
+const SENSITIVE_AUTH_FIELDS = new Set(["refreshToken", "accessToken"]);
+
+function publicAuthEvent(event) {
+  return Object.fromEntries(
+    Object.entries(event).filter(([key]) => !SENSITIVE_AUTH_FIELDS.has(key))
+  );
+}
+
 export function formatAuthLog(event) {
-  return JSON.stringify({
-    type: event.type,
-    userId: event.userId,
-    refreshToken: event.refreshToken,
-    accessToken: event.accessToken
-  });
+  return JSON.stringify(publicAuthEvent(event));
 }
 
 export function writeAuthLog(event, sink = console.log) {
