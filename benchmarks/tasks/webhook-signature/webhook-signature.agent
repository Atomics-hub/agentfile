mission verify-webhook-raw-signature {
  goal "Verify webhook signatures against exact raw request body bytes"
  summary "Accept valid webhook signatures without normalizing JSON before HMAC verification"
  background "Webhook providers sign the exact raw request body bytes. Normal webhook tests can pass while implementations incorrectly parse and reserialize JSON before verifying the signature."
  owner "platform-team"
  label webhooks
  label security
  label proof

  read src/webhooks/**, tests/webhooks/**, package.json, scripts/**
  write src/webhooks/**, tests/webhooks/**

  can run "npm test -- webhooks"
  can run "npm run lint"
  can run "npm run proof:check"

  cannot use network
  cannot read secrets
  cannot add dependency

  must preserve "Valid compact webhook bodies continue to verify"
  must "HMAC verification uses exact raw request body bytes"
  must "Equivalent JSON with different whitespace is verified against its own raw bytes"
  must "Signature comparison uses a constant-time comparison"
  must_not "Parse and reserialize webhook JSON before verifying the signature"

  plan {
    step "Inspect webhook signature verification"
    step "Compute HMAC over the raw body bytes without JSON normalization"
    step "Use constant-time signature comparison"
    step "Run proof vectors for whitespace-sensitive raw bodies"
  }

  prove {
    run "npm test -- webhooks"
    run "npm run lint"
    run "npm run proof:check"
    expect "Valid compact webhook body signatures pass"
    expect "Whitespace-different webhook bodies must be signed against their exact raw bytes"
    expect "Tampered raw bodies fail verification"
    expect "Signature comparison uses timingSafeEqual"
  }

  handoff {
    explain "raw body signature verification behavior"
    list changed_files
    note risks
  }
}
