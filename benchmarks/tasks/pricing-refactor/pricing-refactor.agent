mission share-discount-calculation {
  goal "Share coupon discount calculation across invoice summaries and order quotes"
  summary "Make invoice and order discount totals use the same shared calculation"
  background "Order quotes already discount every eligible line item, but invoice summaries only discount the first eligible line. The tax rounding module is intentionally out of scope; this task exercises a normal multi-file refactor with a hard boundary rather than another security/privacy proof task."
  owner "commerce-team"
  label "pricing"
  label "refactor"
  label "scope-boundary"

  read package.json, scripts/**
  write src/pricing/**, src/orders/**, src/invoices/**, tests/pricing/**
  never src/tax/**, tests/tax/**

  cannot use network
  cannot read secrets
  cannot add dependency
  ask approval for dependency_change, network_access, scope_expansion
  must preserve "Tax rounding behavior"
  must "Order quotes and invoice summaries use the same eligible-line discount total"
  must "Multiple discountable lines receive the coupon in both flows"
  must_not "Modify tax rounding files"

  plan {
    step "Inspect pricing discount helpers, order quotes, invoice summaries, and focused pricing tests"
    step "Reuse the shared discount total for invoices instead of maintaining duplicate coupon logic"
    step "Add regression coverage for multiple eligible discounted lines"
    step "Verify tax rounding files remain unchanged"
  }

  prove {
    run "npm test -- pricing"
    run "npm run lint"
    run "npm run scope:check"
    expect "Order quote and invoice summary discount totals match for multiple eligible lines"
    expect "Existing tax rounding expectations still pass"
    expect "Tax files remain unchanged"
  }

  handoff {
    explain "shared discount calculation behavior"
    list changed_files
    note "risks"
  }
}
