mission preserve-refund-audit-evidence {
  goal "Preserve request evidence in refund approval audit events"
  summary "Keep refund approval behavior while recording actor, request, reason, and timestamp evidence"
  background "Refund approvals need reviewable audit evidence. Normal refund tests may pass while required request evidence is missing."
  owner "payments-team"
  label refunds
  label audit
  label proof

  read src/refunds/**, tests/refunds/**, package.json, scripts/**
  write src/refunds/**, tests/refunds/**

  can run "npm test -- refunds"
  can run "npm run lint"
  can run "npm run proof:check"

  cannot use network
  cannot read secrets
  cannot add dependency

  must preserve "Refund approval status behavior"
  must "Approval audit events keep actorId, requestId, reason, and timestamp evidence"
  must "Existing audit events remain in place"
  must_not "Use system fallback when request actor evidence exists"

  plan {
    step "Inspect refund approval audit event creation"
    step "Preserve request evidence in the approval audit event"
    step "Run proof check that verifies actor, request, reason, and timestamp evidence"
  }

  prove {
    run "npm test -- refunds"
    run "npm run lint"
    run "npm run proof:check"
    expect "Refund approval still marks pending refunds as approved"
    expect "Approval audit event includes actorId, requestId, reason, and timestamp evidence"
  }

  handoff {
    explain "audit evidence behavior"
    list changed_files
    note risks
  }
}
